// Local development schema — SQLite provider.
// DO NOT use for DHP deployment. Use schema.prisma (postgresql) for production.
// To activate: npm run db:use-sqlite
// To switch back: npm run db:use-postgresql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String?
  team      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practiceLogs PracticeLog[]
  decisionLogs DecisionLog[]
  medicalCases MedicalCase[]
  bigFives     BigFive[]
  followUps    FollowUp[]
}

model Principle {
  id               String   @id @default(cuid())
  number           Int      @unique
  name             String
  intent           String
  objectives       String
  behaviours       String
  shortDescription String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  activities   Activity[]
  practiceLogs PracticeLog[]
}

model Activity {
  id          String       @id @default(cuid())
  principleId String
  name        String
  duration    String
  steps       String
  type        ActivityType
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  principle    Principle     @relation(fields: [principleId], references: [id])
  practiceLogs PracticeLog[]
}

enum ActivityType {
  FOUR_QS
  MEDICAL_MODEL
  BIG_FIVE
  SIMPLE_FEEDBACK
  OBJECTIONS_CLINIC
  GENERIC
}

model PracticeLog {
  id          String      @id @default(cuid())
  userId      String
  principleId String
  activityId  String?
  date        DateTime    @default(now())
  notes       String
  status      LogStatus   @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  principle Principle @relation(fields: [principleId], references: [id])
  activity  Activity? @relation(fields: [activityId], references: [id])
}

enum LogStatus {
  DRAFT
  COMPLETE
}

model DecisionLog {
  id           String        @id @default(cuid())
  userId       String
  decision     String
  q1Answer     QAnswer
  q1Why        String        @default("")
  q2Answer     QAnswer
  q2Why        String        @default("")
  q3Answer     QAnswer
  q3Why        String        @default("")
  q4Answer     QAnswer
  q4Why        String        @default("")
  outcome      Outcome
  followUpDate DateTime?
  followUpNote String        @default("")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum QAnswer {
  YES
  NO
  UNSURE
}

enum Outcome {
  PROCEED
  PAUSE
  AMEND
  STOP
}

model MedicalCase {
  id           String    @id @default(cuid())
  userId       String
  title        String
  symptoms     String
  diagnosis    String
  treatment    String
  followUp     String    @default("")
  followUpDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model BigFive {
  id           String    @id @default(cuid())
  userId       String
  topic        String
  priorities   String
  followUpDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model FollowUp {
  id         String           @id @default(cuid())
  userId     String
  sourceType FollowUpSource
  sourceId   String?
  commitment String
  owner      String           @default("me")
  dueDate    DateTime
  status     FollowUpStatus   @default(OPEN)
  outcome    String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum FollowUpSource {
  DECISION
  MEDICAL
  BIG_FIVE
  COACHING
  MANUAL
}

enum FollowUpStatus {
  OPEN
  DONE
  CANCELLED
}
