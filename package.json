{
  "name": "leadlab",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "LeadLab backend API and frontend",
  "main": "server.mjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.mjs",
    "dev": "concurrently -n server,frontend -c red,blue \"npm:dev:server\" \"npm:dev:frontend\"",
    "dev:server": "nodemon server.mjs",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build -- --outDir ../static --emptyOutDir",
    "install:all": "npm install && npm --prefix frontend install",
    "db:seed": "node seed/run.js",
    "db:schema": "node -e \"import('./local-modules/db.mjs').then(m=>m.setup())\""
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.9"
  }
}
